/* Page Headers */
.page-header {
  height: 400px;
  background-size: cover;
  background-position: center;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  margin-top: 80px; /* Offset for navbar */
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 74, 159, 0.7);
}

.header-content {
  position: relative;
  z-index: 10;
  color: var(--white);
}

.header-title {
  font-size: 3rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.header-subtitle {
  font-size: 1.2rem;
  opacity: 0.9;
}

/* About Main Section */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.about-image-container {
  position: relative;
}

.image-card {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0, 74, 159, 0.15);
}

.about-img {
  width: 100%;
  height: auto;
  transition: transform 0.5s ease;
}

.image-card:hover .about-img {
  transform: scale(1.05);
}

.experience-badge {
  position: absolute;
  bottom: 30px;
  right: -20px;
  background-color: var(--white);
  padding: 1.5rem 2.5rem;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.badge-title {
  font-size: 0.9rem;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.badge-value {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--primary-blue);
}

/* Timeline */
.bg-light {
  background-color: var(--bg-color);
}

.text-center {
  text-align: center;
}

.title-underline.center {
  margin: 0 auto 3rem;
}

.timeline {
  max-width: 800px;
  margin: 0 auto;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4px;
  height: 100%;
  background-color: var(--light-blue);
  border-radius: 2px;
}

.timeline-item {
  position: relative;
  padding-left: 3rem;
  margin-bottom: 3rem;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -8px;
  top: 0;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background-color: var(--primary-blue);
  border: 4px solid var(--white);
  box-shadow: 0 0 0 4px var(--light-blue);
}

.timeline-content {
  background-color: var(--white);
  padding: 2rem;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  transition: var(--transition);
}

.timeline-content:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
}

.timeline-year {
  display: inline-block;
  padding: 0.5rem 1rem;
  background-color: var(--light-blue);
  color: var(--primary-blue);
  font-weight: 600;
  border-radius: 50px;
  margin-bottom: 1rem;
}

.timeline-title {
  font-size: 1.5rem;
  color: var(--primary-blue-dark);
  margin-bottom: 1rem;
}

.timeline-text {
  color: #475569;
}

@media screen and (max-width: 992px) {
  .about-grid {
    grid-template-columns: 1fr;
  }
}

@media screen and (max-width: 768px) {
  .header-title {
    font-size: 2.5rem;
  }
  
  .experience-badge {
    right: 20px;
  }
}
